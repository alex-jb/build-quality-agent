# Required: Anthropic API key. Without it, the agent prints a warning
# and passes (graceful degradation — never blocks a push because the
# agent itself isn't configured).
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override the model. Defaults to claude-haiku-4-5 because
# diff review is a fast cheap task. Use claude-sonnet-4-6 for higher
# quality on complex diffs.
# BUILD_AGENT_MODEL=claude-haiku-4-5

# Optional: set to "1" to skip review entirely (e.g. on CI machines
# that already have CI build gates).
# BUILD_AGENT_SKIP=0
